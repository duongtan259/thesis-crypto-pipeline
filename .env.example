# ── Copy this to .env and fill in values ──────────────────────────────
# NEVER commit .env to git

# ── Azure Event Hub (fill in after creating Azure account) ────────────
EVENTHUB_CONNECTION_STRING=
EVENTHUB_NAME=crypto-prices

# ── Local dev (Kafka) — works right now without Azure ─────────────────
USE_LOCAL_KAFKA=true
KAFKA_BOOTSTRAP=localhost:9092
KAFKA_TOPIC=crypto-prices

# ── Data source ────────────────────────────────────────────────────────
# "coinbase_ws"    = Coinbase WebSocket (true push, best for thesis)
# "coingecko_rest" = CoinGecko REST polling (fallback, 10s intervals)
DATA_SOURCE=coinbase_ws

# ── Symbols to track ───────────────────────────────────────────────────
SYMBOLS=BTC-USD,ETH-USD,SOL-USD,BNB-USD,XRP-USD,ADA-USD,DOGE-USD,AVAX-USD

# ── Throughput ─────────────────────────────────────────────────────────
BATCH_SIZE=50
MAX_EVENTS_PER_SECOND=0   # 0 = unlimited (as fast as Coinbase pushes)
POLL_INTERVAL=10.0        # seconds between CoinGecko polls (if used)
